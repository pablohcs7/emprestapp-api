NODE_ENV=development
PORT=3000
API_HOST_PORT=3000
API_BIND_ADDRESS=127.0.0.1
MONGODB_URI=mongodb://emprestapp_app:replace-with-a-secure-db-password@localhost:27017/emprestapp_dev?authSource=admin
CORS_ALLOWED_ORIGINS=http://localhost:3001
TRUST_PROXY=false
MONGODB_ROOT_USERNAME=emprestapp_root
MONGODB_ROOT_PASSWORD=replace-with-a-secure-root-password
MONGODB_APP_USERNAME=emprestapp_app
MONGODB_APP_PASSWORD=replace-with-a-secure-db-password
JWT_ACCESS_SECRET=replace-with-a-secure-access-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=replace-with-a-secure-refresh-secret
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=10
